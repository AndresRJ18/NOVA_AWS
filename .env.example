# ============================================================================
# Nova Sonic Voice Integration - Environment Variables
# ============================================================================
# This file documents all environment variables required for deploying the
# Mock Interview Coach with Nova Sonic voice integration to Vercel.
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env.local for local development
# 2. Fill in the required values (marked as REQUIRED)
# 3. Configure optional values as needed
# 4. For Vercel deployment, set these via CLI or dashboard (see below)
# ============================================================================

# ----------------------------------------------------------------------------
# REQUIRED VARIABLES
# ----------------------------------------------------------------------------
# These variables MUST be set for the application to function properly.

# AWS Region where Amazon Bedrock is available
# Common regions: us-east-1, us-west-2, eu-west-1
# Check availability: https://docs.aws.amazon.com/bedrock/latest/userguide/bedrock-regions.html
AWS_REGION=us-east-1

# AWS Access Key ID with permissions to invoke Amazon Bedrock
# Required IAM permissions: bedrock:InvokeModel, bedrock:InvokeModelWithResponseStream
# Create IAM user: https://console.aws.amazon.com/iam/
AWS_ACCESS_KEY_ID=your_access_key_id_here

# AWS Secret Access Key (keep this secure!)
# Never commit this to version control
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# Nova Sonic Model ID
# Options:
#   - amazon.nova-sonic-v1:0 (default, balanced cost/quality)
#   - amazon.nova-2-sonic-v1:0 (higher quality, higher cost)
# The system validates model availability in your AWS region on startup
NOVA_SONIC_MODEL_ID=amazon.nova-sonic-v1:0

# ----------------------------------------------------------------------------
# OPTIONAL VARIABLES
# ----------------------------------------------------------------------------
# These variables have sensible defaults but can be customized.

# Audio Cache Size (in megabytes)
# Controls how much audio is cached in memory to reduce API calls
# Larger cache = fewer API calls but more memory usage
# Default: 100 MB
# Recommended range: 50-200 MB
AUDIO_CACHE_SIZE_MB=100

# Maximum Audio Duration (in seconds)
# Limits how long users can record to prevent abuse and excessive costs
# Default: 300 seconds (5 minutes)
# Recommended range: 60-600 seconds
MAX_AUDIO_DURATION_SECONDS=300

# Development Mode
# When enabled, uses mock audio files instead of calling Nova Sonic API
# Useful for local development without AWS credentials
# Options: true, false
# Default: false
ENABLE_DEV_MODE=false

# Logging Level
# Controls verbosity of application logs
# Options: DEBUG, INFO, WARN, ERROR
# Default: INFO
# Use DEBUG for troubleshooting, ERROR for production
LOG_LEVEL=INFO

# Rate Limiting - Maximum Requests
# Maximum number of requests allowed per client IP within the time window
# Prevents abuse and excessive API usage
# Default: 100 requests
# Recommended range: 50-200 requests
RATE_LIMIT_MAX_REQUESTS=100

# Rate Limiting - Time Window (in seconds)
# Time window for rate limiting in seconds
# Default: 60 seconds (1 minute)
# Recommended range: 30-300 seconds
RATE_LIMIT_WINDOW_SECONDS=60

# ----------------------------------------------------------------------------
# COGNITO AUTH (optional — leave empty for demo-only mode)
# ----------------------------------------------------------------------------
# When all three Cognito vars are set, Google Sign-In becomes available.
# The app works without them (demo-only mode).

COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_DOMAIN=
COGNITO_REDIRECT_URI=
COGNITO_REGION=us-east-1

# ----------------------------------------------------------------------------
# DYNAMODB (optional — session records skipped silently if not configured)
# ----------------------------------------------------------------------------
DYNAMO_USERS_TABLE=nova_users
DYNAMO_SESSIONS_TABLE=nova_sessions

# ----------------------------------------------------------------------------
# VERCEL DEPLOYMENT INSTRUCTIONS
# ----------------------------------------------------------------------------

# METHOD 1: Vercel CLI
# ----------------------
# Install Vercel CLI:
#   npm install -g vercel
#
# Login to Vercel:
#   vercel login
#
# Add environment variables (one at a time):
#   vercel env add AWS_REGION production
#   vercel env add AWS_ACCESS_KEY_ID production
#   vercel env add AWS_SECRET_ACCESS_KEY production
#   vercel env add NOVA_SONIC_MODEL_ID production
#
# Optional variables (if customizing defaults):
#   vercel env add AUDIO_CACHE_SIZE_MB production
#   vercel env add MAX_AUDIO_DURATION_SECONDS production
#   vercel env add ENABLE_DEV_MODE production
#   vercel env add LOG_LEVEL production
#
# Deploy to production:
#   vercel --prod

# METHOD 2: Vercel Dashboard
# ---------------------------
# 1. Go to https://vercel.com/dashboard
# 2. Select your project
# 3. Go to Settings → Environment Variables
# 4. Add each variable:
#    - Key: Variable name (e.g., AWS_REGION)
#    - Value: Variable value (e.g., us-east-1)
#    - Environment: Select "Production" (and "Preview" if needed)
# 5. Click "Save"
# 6. Redeploy your application for changes to take effect

# METHOD 3: Vercel Git Integration (Recommended)
# -----------------------------------------------
# 1. Set up environment variables via dashboard (Method 2)
# 2. Connect your GitHub/GitLab/Bitbucket repository
# 3. Push to main branch → automatic production deployment
# 4. Push to other branches → automatic preview deployments

# ----------------------------------------------------------------------------
# SECURITY BEST PRACTICES
# ----------------------------------------------------------------------------
# 1. NEVER commit .env or .env.local files to version control
# 2. Add .env* to .gitignore (except .env.example)
# 3. Use AWS IAM user with minimal permissions (Bedrock invoke only)
# 4. Rotate AWS credentials regularly
# 5. Use different AWS credentials for development and production
# 6. Monitor AWS usage via CloudWatch and set up billing alerts

# ----------------------------------------------------------------------------
# AWS IAM PERMISSIONS
# ----------------------------------------------------------------------------
# Create an IAM user with this policy for minimal required permissions:
#
# {
#   "Version": "2012-10-17",
#   "Statement": [
#     {
#       "Effect": "Allow",
#       "Action": [
#         "bedrock:InvokeModel",
#         "bedrock:InvokeModelWithResponseStream"
#       ],
#       "Resource": [
#         "arn:aws:bedrock:*::foundation-model/amazon.nova-sonic-v1:0",
#         "arn:aws:bedrock:*::foundation-model/amazon.nova-2-sonic-v1:0"
#       ]
#     }
#   ]
# }

# ----------------------------------------------------------------------------
# MONITORING AWS COSTS
# ----------------------------------------------------------------------------
# Monitor Nova Sonic usage and costs via AWS Console:
#
# 1. Access Bedrock Metrics:
#    - Go to AWS Console → Amazon Bedrock
#    - Click "Monitoring" → "Usage metrics"
#    - Filter by model: amazon.nova-sonic-v1:0
#
# 2. View Costs:
#    - Go to AWS Console → Billing Dashboard
#    - View costs by service (Amazon Bedrock)
#    - Track daily/weekly/monthly spending
#
# 3. Set Up Cost Alerts:
#    - Go to AWS Console → Billing → Budgets
#    - Create new budget (e.g., $100/month)
#    - Set alerts at 80% and 100% of budget
#    - Configure email notifications
#
# Useful links:
# - Bedrock Pricing: https://aws.amazon.com/bedrock/pricing/
# - Cost Management: https://aws.amazon.com/aws-cost-management/

# ----------------------------------------------------------------------------
# TROUBLESHOOTING
# ----------------------------------------------------------------------------
# Issue: "Nova Sonic unavailable" error
# Solution: Verify AWS_REGION supports Bedrock and model is available
#
# Issue: "Permission denied" error
# Solution: Check IAM user has bedrock:InvokeModel permission
#
# Issue: "Invalid credentials" error
# Solution: Verify AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY are correct
#
# Issue: High latency (>3 seconds)
# Solution: Check AWS_REGION is geographically close to your users
#
# Issue: High costs
# Solution: Increase AUDIO_CACHE_SIZE_MB to cache more responses

# ----------------------------------------------------------------------------
# VALIDATION
# ----------------------------------------------------------------------------
# After setting environment variables, validate the configuration:
#
# 1. Deploy to Vercel preview:
#    vercel
#
# 2. Check health endpoint:
#    curl https://your-app-preview.vercel.app/api/health
#
# 3. Expected response:
#    {
#      "status": "healthy",
#      "nova_sonic": "available",
#      "timestamp": "2024-01-01T00:00:00Z"
#    }
#
# 4. If status is "unhealthy", check Vercel logs:
#    vercel logs
